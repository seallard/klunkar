#!/usr/bin/env bash
# Format and lint staged Python files. Re-stages whatever the formatter changed.
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

mapfile -t files < <(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)
[ ${#files[@]} -eq 0 ] && exit 0

RUFF=".venv/bin/ruff"
[ -x "$RUFF" ] || { echo "pre-commit: $RUFF not found — run 'pip install ruff>=0.6' in .venv"; exit 1; }

"$RUFF" format "${files[@]}"
"$RUFF" check --fix "${files[@]}"
"$RUFF" check "${files[@]}"

git add -- "${files[@]}"
